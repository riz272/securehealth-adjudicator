# Defaults: extraction runs against a local Ollama model, no key needed.
# LLM_MODEL=qwen2.5:7b-instruct
# LLM_BASE_URL=http://localhost:11434/v1

# To use a hosted OpenAI-compatible provider instead, set:
# OPENAI_API_KEY=your-api-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
